DATABASE_URL=sqlite:///./data.db
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
WORKSPACE_ROOT=../workspaces
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
SKILLHUB_API_KEY=
AGENT_MAX_CONCURRENCY=4
MERGE_MAX_CONCURRENCY=2
# Legacy fallback for QUALITY_GATE_UNIT_TEST_COMMAND.
# Examples: npm.cmd test   |   .venv\\Scripts\\python.exe -m pytest
MERGE_TEST_COMMAND=
MERGE_TEST_TIMEOUT_SECONDS=300

# Deterministic pre-merge quality gates.
# Unit tests, dependency audit and coverage are required and fail closed when
# their commands are empty. Other commands extend the built-in scanners.
QUALITY_GATE_UNIT_TEST_COMMAND=
QUALITY_GATE_STYLE_COMMAND=
QUALITY_GATE_STATIC_SCAN_COMMAND=
QUALITY_GATE_SECRET_SCAN_COMMAND=
QUALITY_GATE_DEPENDENCY_AUDIT_COMMAND=
QUALITY_GATE_COVERAGE_COMMAND=
QUALITY_GATE_BANK_RULE_COMMAND=
QUALITY_GATE_FORBIDDEN_PATTERNS=TODO,FIXME
QUALITY_GATE_TIMEOUT_SECONDS=300
